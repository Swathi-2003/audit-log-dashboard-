# Copy this file to .env and fill in your values
# Command: cp .env.example .env  (Mac/Linux)  OR  copy .env.example .env  (Windows)

PORT=5000

# Get this from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Connect" on your cluster
# 3. Choose "Drivers" and copy the connection string
# 4. Replace <password> with your database user's password
# 5. Add /audit_logs before the ? in the URL
#
# Example format:
# MONGO_URI=mongodb+srv://youruser:yourpassword@yourcluster.mongodb.net/audit_logs?appName=yourapp
MONGO_URI=YOUR_MONGODB_ATLAS_CONNECTION_STRING_HERE
